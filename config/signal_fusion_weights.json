  "interaction_terms": {
    "momentum_volume_bonus": {
      "dimensions": ["technical_momentum", "microstructure"],
      "bonus_weight": 0.03,
      "description": "Momentum confirmed by volume anomaly = stronger signal"
    },
    "earnings_fundamental_synergy": {
      "dimensions": ["earnings_quality", "fundamentals"],
      "bonus_weight": 0.02,
      "description": "Strong earnings on solid fundamentals = synergistic boost"
    }
