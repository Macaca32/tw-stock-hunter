  "calibration": {
    "method": "isotonic_regression",
    "sigmoid_k": 1.0,
    "sigmoid_x0": 50.0,
    "description": "Raw weighted sum mapped through sigmoid to [0,1], then calibrated via isotonic regression against historical win rates"
  }
